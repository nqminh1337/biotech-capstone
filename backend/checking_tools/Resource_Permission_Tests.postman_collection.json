{
  "info": {
    "_postman_id": "resource-permission-tests",
    "name": "Resource Permission Tests",
    "description": "Comprehensive tests for role-based permissions on resource operations (CREATE, PATCH, DELETE)",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Admin Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    pm.test('Admin login successful', function () {",
                  "        pm.response.to.have.status(200);",
                  "    });",
                  "    ",
                  "    // Extract session cookies",
                  "    const cookies = pm.cookies.all();",
                  "    pm.test('Session cookies received', function () {",
                  "        pm.expect(cookies.length).to.be.greaterThan(0);",
                  "    });",
                  "} else {",
                  "    pm.test('Admin login failed', function () {",
                  "        pm.response.to.have.status(200);",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/x-www-form-urlencoded"
              }
            ],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "admin@biotech.com",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "admin123",
                  "type": "text"
                },
                {
                  "key": "csrfmiddlewaretoken",
                  "value": "{{csrf_token}}",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/admin/login/",
              "host": ["{{base_url}}"],
              "path": ["admin", "login", ""]
            },
            "description": "Login as admin user to get session cookies"
          },
          "response": []
        },
        {
          "name": "Get CSRF Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// Extract CSRF token from response",
                  "const responseText = pm.response.text();",
                  "const csrfMatch = responseText.match(/name='csrfmiddlewaretoken' value='([^']+)'/);",
                  "",
                  "if (csrfMatch) {",
                  "    pm.environment.set('csrf_token', csrfMatch[1]);",
                  "    pm.test('CSRF token extracted', function () {",
                  "        pm.expect(csrfMatch[1]).to.be.a('string');",
                  "    });",
                  "} else {",
                  "    pm.test('CSRF token not found', function () {",
                  "        pm.expect.fail('CSRF token not found in response');",
                  "    });",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/admin/login/",
              "host": ["{{base_url}}"],
              "path": ["admin", "login", ""]
            },
            "description": "Get CSRF token for admin login"
          },
          "response": []
        }
      ],
      "description": "Authentication setup for admin user"
    },
    {
      "name": "Student Permission Tests (Should FAIL)",
      "item": [
        {
          "name": "Student - Create Resource (403 Forbidden)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Student cannot create resource', function () {",
                  "    pm.response.to.have.status(403);",
                  "});",
                  "",
                  "pm.test('Response contains forbidden message', function () {",
                  "    const responseData = pm.response.json();",
                  "    pm.expect(responseData).to.have.property('detail');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "X-CSRFToken",
                "value": "{{csrf_token}}"
              }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "resource_name",
                  "value": "Student Test Resource",
                  "type": "text"
                },
                {
                  "key": "resource_description",
                  "value": "Testing student create permission",
                  "type": "text"
                },
                {
                  "key": "resource_file",
                  "type": "file",
                  "src": "test_file.txt"
                },
                {
                  "key": "resource_type_id",
                  "value": "1",
                  "type": "text"
                },
                {
                  "key": "role_ids",
                  "value": "4",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/resources/resource-files/",
              "host": ["{{base_url}}"],
              "path": ["resources", "resource-files", ""]
            },
            "description": "Test that students cannot create resources - should return 403 Forbidden"
          },
          "response": []
        },
        {
          "name": "Student - PATCH Resource (403 Forbidden)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Student cannot modify resource', function () {",
                  "    pm.response.to.have.status(403);",
                  "});",
                  "",
                  "pm.test('Response contains forbidden message', function () {",
                  "    const responseData = pm.response.json();",
                  "    pm.expect(responseData).to.have.property('detail');",
